# Virtual environment (per CLAUDE.md — not committed)
.venv/

# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# macOS
.DS_Store

# Local AWS / secrets — never commit credentials
.aws/
*.env

# Terraform — commit .tf files and .terraform.lock.hcl; ignore the rest.
# State can contain secrets/tokens and must never be committed.
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
crash.log
